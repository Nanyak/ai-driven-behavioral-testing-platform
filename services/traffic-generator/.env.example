# Traffic generator configuration.
# Values fall back to the repository root .env when unset here.

# Target Medusa instance
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_PUBLISHABLE_API_KEY=
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=change-me

# LLM-varied traffic (Haiku 4.5 for bulk narrative generation).
# When ANTHROPIC_API_KEY is unset, the generator falls back to a local
# stochastic narrative generator so the run still completes offline.
ANTHROPIC_API_KEY=
TRAFFIC_LLM_MODEL=claude-haiku-4-5-20251001

# Situation mix (plan §4). The profile sets relative weights over the 18-leaf
# taxonomy; counts are normalized to the total, then floored (plan §7).
#   realistic   — default shape (N≈300)
#   signal-rich — same shape, purchase/return/refund leaves boosted for mining
#   smoke       — tiny run (N≈40) for a quick structural check
MIX_PROFILE=realistic
# Override the profile defaults if needed.
TRAFFIC_TOTAL_SESSIONS=300
ACCOUNT_POOL_SIZE=25
TRAFFIC_CONCURRENCY=5

# Deal-seeker promo codes (plan §4.1). The valid code is SEEDED in Stage 0 via
# the Admin API so discount-conditional conversions can actually succeed; the
# invalid code exercises the "tried a code that didn't apply" path.
TRAFFIC_VALID_PROMO=SAVE10
TRAFFIC_INVALID_PROMO=WELCOME10
