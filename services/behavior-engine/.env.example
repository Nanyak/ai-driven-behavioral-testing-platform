# Behavior engine configuration.
# Copy to .env and fill in. Values fall back to the repository root .env when
# unset here. The .env file is gitignored — never commit a real key.

# LLM judgment calls (flow naming, anomaly/contamination notes, advisory
# assertion hints). Classification stays deterministic and never calls the LLM.
# When ANTHROPIC_API_KEY is unset, naming degrades to a deterministic offline
# fallback so the run still completes; all acceptance gates are unaffected.
ANTHROPIC_API_KEY=

# Sonnet 4.6 for naming (judgment only, never classification). Override to
# claude-opus-4-8 for the most capable naming, or another model id.
BEHAVIOR_LLM_MODEL=claude-sonnet-4-6
