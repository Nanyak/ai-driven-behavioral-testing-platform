erDiagram
    %% ─── PRODUCT MODULE ───────────────────────────────────────────────────────
    product {
        string id PK
        string title
        string handle
        string status
        string description
        string thumbnail
        string collection_id FK
        string type_id FK
        boolean discountable
        boolean is_giftcard
        json metadata
    }
    product_variant {
        string id PK
        string title
        string sku
        string barcode
        boolean allow_backorder
        boolean manage_inventory
        string product_id FK
    }
    product_option {
        string id PK
        string title
        string product_id FK
    }
    product_option_value {
        string id PK
        string value
        string option_id FK
        string variant_id FK
    }
    product_collection {
        string id PK
        string title
        string handle
    }
    product_category {
        string id PK
        string name
        string handle
        boolean is_active
        string parent_category_id FK
    }
    product_type {
        string id PK
        string value
    }
    product_image {
        string id PK
        string url
        int rank
        string product_id FK
    }
    product_tag {
        string id PK
        string value
    }

    %% ─── PRICING MODULE ───────────────────────────────────────────────────────
    price_set {
        string id PK
    }
    money_amount {
        string id PK
        string currency_code
        decimal amount
        int min_quantity
        int max_quantity
        string price_set_id FK
        string price_list_id FK
    }
    price_list {
        string id PK
        string title
        string status
        string type
        datetime starts_at
        datetime ends_at
    }
    price_rule {
        string id PK
        string attribute
        string operator
        string value
        int priority
        string price_set_id FK
    }

    %% ─── CART MODULE ──────────────────────────────────────────────────────────
    cart {
        string id PK
        string email
        string currency_code
        string region_id FK
        string customer_id FK
        string sales_channel_id FK
        string billing_address_id FK
        string shipping_address_id FK
        datetime completed_at
    }
    line_item {
        string id PK
        string title
        int quantity
        decimal unit_price
        string cart_id FK
        string variant_id FK
        string product_id FK
    }
    cart_address {
        string id PK
        string first_name
        string last_name
        string address_1
        string city
        string country_code
        string postal_code
    }
    cart_shipping_method {
        string id PK
        string name
        decimal amount
        string cart_id FK
        string shipping_option_id FK
    }

    %% ─── ORDER MODULE ─────────────────────────────────────────────────────────
    order {
        string id PK
        string status
        string currency_code
        string email
        string customer_id FK
        string sales_channel_id FK
        string region_id FK
    }
    order_item {
        string id PK
        string title
        int quantity
        decimal unit_price
        string order_id FK
        string variant_id FK
    }
    order_address {
        string id PK
        string first_name
        string last_name
        string address_1
        string city
        string country_code
        string order_id FK
    }
    order_transaction {
        string id PK
        decimal amount
        string currency_code
        string reference
        string reference_id
        string order_id FK
    }

    %% ─── CUSTOMER MODULE ──────────────────────────────────────────────────────
    customer {
        string id PK
        string first_name
        string last_name
        string email
        string phone
        boolean has_account
    }
    customer_address {
        string id PK
        string first_name
        string last_name
        string address_1
        string city
        string country_code
        string customer_id FK
    }
    customer_group {
        string id PK
        string name
    }

    %% ─── REGION MODULE ────────────────────────────────────────────────────────
    region {
        string id PK
        string name
        string currency_code
        boolean automatic_taxes
    }
    region_country {
        string id PK
        string iso_2
        string name
        string region_id FK
    }

    %% ─── FULFILLMENT MODULE ───────────────────────────────────────────────────
    fulfillment_set {
        string id PK
        string name
        string type
    }
    service_zone {
        string id PK
        string name
        string fulfillment_set_id FK
    }
    geo_zone {
        string id PK
        string type
        string country_code
        string province_code
        string service_zone_id FK
    }
    shipping_option {
        string id PK
        string name
        string price_type
        string provider_id
        string service_zone_id FK
        string shipping_profile_id FK
    }
    shipping_profile {
        string id PK
        string name
        string type
    }
    fulfillment {
        string id PK
        string location_id
        datetime shipped_at
        datetime delivered_at
        string provider_id
        string order_id FK
    }
    fulfillment_item {
        string id PK
        string title
        string sku
        int quantity
        string fulfillment_id FK
        string line_item_id FK
    }

    %% ─── INVENTORY MODULE ─────────────────────────────────────────────────────
    inventory_item {
        string id PK
        string sku
        string title
        boolean requires_shipping
    }
    inventory_level {
        string id PK
        string location_id
        int stocked_quantity
        int reserved_quantity
        int incoming_quantity
        string inventory_item_id FK
    }
    reservation_item {
        string id PK
        string location_id
        int quantity
        string inventory_item_id FK
        string line_item_id FK
    }

    %% ─── STOCK LOCATION MODULE ────────────────────────────────────────────────
    stock_location {
        string id PK
        string name
    }
    stock_location_address {
        string id PK
        string address_1
        string city
        string country_code
        string stock_location_id FK
    }

    %% ─── PAYMENT MODULE ───────────────────────────────────────────────────────
    payment_collection {
        string id PK
        string status
        string currency_code
        decimal amount
        decimal authorized_amount
        decimal captured_amount
        string region_id FK
    }
    payment_session {
        string id PK
        string status
        decimal amount
        string provider_id
        string payment_collection_id FK
    }
    payment {
        string id PK
        decimal amount
        string currency_code
        string provider_id
        string payment_collection_id FK
        string payment_session_id FK
    }

    %% ─── SALES CHANNEL MODULE ─────────────────────────────────────────────────
    sales_channel {
        string id PK
        string name
        string description
        boolean is_disabled
    }

    %% ─── TAX MODULE ───────────────────────────────────────────────────────────
    tax_region {
        string id PK
        string country_code
        string province_code
        string provider_id
        string parent_id FK
    }
    tax_rate {
        string id PK
        float rate
        string code
        string name
        boolean is_default
        string tax_region_id FK
    }
    tax_rate_rule {
        string id PK
        string reference
        string reference_id
        string tax_rate_id FK
    }

    %% ─── AUTH MODULE ──────────────────────────────────────────────────────────
    auth_identity {
        string id PK
        json app_metadata
    }
    provider_identity {
        string id PK
        string entity_id
        string provider
        string auth_identity_id FK
    }

    %% ─── USER MODULE ──────────────────────────────────────────────────────────
    user {
        string id PK
        string first_name
        string last_name
        string email
        string avatar_url
    }
    invite {
        string id PK
        string email
        boolean accepted
        string token
        datetime expires_at
    }

    %% ─── API KEY MODULE ───────────────────────────────────────────────────────
    api_key {
        string id PK
        string token
        string title
        string type
        datetime revoked_at
        string created_by
    }

    %% ─── STORE MODULE ─────────────────────────────────────────────────────────
    store {
        string id PK
        string name
        string default_sales_channel_id FK
    }
    store_currency {
        string id PK
        string currency_code
        boolean is_default
        string store_id FK
    }

    %% ─── RELATIONSHIPS ────────────────────────────────────────────────────────
    product ||--o{ product_variant : "has"
    product ||--o{ product_option : "has"
    product ||--o{ product_image : "has"
    product }o--|| product_collection : "belongs_to"
    product }o--|| product_type : "has"
    product_option ||--o{ product_option_value : "has"
    product_variant ||--o{ product_option_value : "has"
    product_category ||--o{ product_category : "parent_of"

    price_set ||--o{ money_amount : "has"
    price_set ||--o{ price_rule : "has"
    price_list ||--o{ money_amount : "has"

    cart ||--o{ line_item : "contains"
    cart ||--o{ cart_shipping_method : "has"
    cart }o--|| cart_address : "billing"
    cart }o--|| cart_address : "shipping"
    cart }o--|| region : "belongs_to"
    cart }o--|| customer : "belongs_to"
    cart }o--|| sales_channel : "belongs_to"
    line_item }o--|| product_variant : "references"
    cart_shipping_method }o--|| shipping_option : "uses"

    order ||--o{ order_item : "contains"
    order ||--o{ order_address : "has"
    order ||--o{ order_transaction : "has"
    order ||--o{ fulfillment : "fulfilled_by"
    order }o--|| region : "belongs_to"
    order }o--|| customer : "placed_by"
    order }o--|| sales_channel : "sold_via"
    order_item }o--|| product_variant : "references"

    customer ||--o{ customer_address : "has"
    customer_group }o--o{ customer : "groups"

    region ||--o{ region_country : "covers"

    fulfillment_set ||--o{ service_zone : "has"
    service_zone ||--o{ geo_zone : "has"
    service_zone ||--o{ shipping_option : "offers"
    shipping_option }o--|| shipping_profile : "uses"
    fulfillment ||--o{ fulfillment_item : "contains"

    inventory_item ||--o{ inventory_level : "stocked_at"
    inventory_item ||--o{ reservation_item : "reserved_in"

    stock_location ||--o| stock_location_address : "has"

    payment_collection ||--o{ payment_session : "has"
    payment_collection ||--o{ payment : "has"
    payment_session ||--|| payment : "results_in"
    payment_collection }o--|| region : "for"

    tax_region ||--o{ tax_rate : "has"
    tax_region ||--o{ tax_region : "parent_of"
    tax_rate ||--o{ tax_rate_rule : "has"

    auth_identity ||--o{ provider_identity : "has"

    store ||--o{ store_currency : "supports"
    store }o--|| sales_channel : "default"
