# Medusa
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=change-me
MEDUSA_PUBLISHABLE_API_KEY=
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# Database
DATABASE_URL=postgres://medusa:medusa@postgres:5432/medusa
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=medusa
POSTGRES_USER=medusa
POSTGRES_PASSWORD=medusa

# Redis
REDIS_URL=redis://redis:6379

# ELK
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=behavior-logs-*
KIBANA_URL=http://localhost:5601
LOGSTASH_BEATS_URL=localhost:5044
LOGSTASH_HTTP_URL=http://localhost:8080

# Behavioral platform
NODE_ENV=development
LOG_LEVEL=info
LOG_OUTPUT_PATH=./logs/medusa-json.log
# Simulate production logs: bodies-off (cost + PII), environment tag = production.
LOG_CAPTURE_BODIES=false
LOG_ENVIRONMENT=production
TRAFFIC_SESSION_COUNT=20

# Resolver-agent repair (script-generator). Required ONLY for the "Repair" pipeline
# job (dashboard /api/pipeline/run repair, or `npm run script-generator:repair`):
# the Claude CLI authenticates with this key. On the host the CLI may already be
# logged in, so it's optional there; in Docker it must be set here (loaded via
# env_file). Leave blank to disable repair — mine/generate/run/triage are unaffected.
ANTHROPIC_API_KEY=
