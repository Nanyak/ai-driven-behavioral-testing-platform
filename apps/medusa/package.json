{
  "name": "@dtc/medusa-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "!apps/backend/.medusa/**"
  ],
  "scripts": {
    "backend:build": "npm --workspace @dtc/backend run build",
    "backend:dev": "npm --workspace @dtc/backend run dev",
    "backend:start": "npm --workspace @dtc/backend run start",
    "backend:setup": "npm --workspace @dtc/backend run setup",
    "backend:seed": "npm --workspace @dtc/backend run seed"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  },
  "overrides": {
    "ajv": "^8.0.0"
  }
}
